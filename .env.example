# ─────────────────────────────────────────────────────────────
#  YoRespondo — agente de WhatsApp
#
#  Copia como .env.local para correr `vercel dev`.
#  En producción NINGUNA de estas se captura aquí: van en
#  Vercel → Project Settings → Environment Variables.
#
#  Todas son secretas. Este repo NO debe ser público con un .env dentro.
# ─────────────────────────────────────────────────────────────

# ── Claude ──
# platform.claude.com → API keys → Create key.
# Ojo: el plan gratuito "Evaluation access" no sirve para producción;
# hay que darle Set up billing.
ANTHROPIC_API_KEY=

# ── WhatsApp Cloud API ──
# Token PERMANENTE de un System User (Business Settings → Users →
# System users → Generate token, con permisos whatsapp_business_messaging
# y whatsapp_business_management).
# El que sale en la pantalla de API Setup dura 24 horas: no sirve.
WHATSAPP_TOKEN=

# Una cadena que TÚ te inventas. La escribes aquí y la misma la pegas
# en Meta al registrar el webhook. Sirve para que Meta compruebe que
# el endpoint es tuyo. Que sea larga y aleatoria.
WHATSAPP_VERIFY_TOKEN=

# App Secret de tu app en Meta (App Settings → Basic → App Secret).
# Firma cada webhook. Sin esto cualquiera que descubra la URL podría
# mandarnos mensajes falsos a nombre de tus clientes.
META_APP_SECRET=

# ── Supabase ──
# Las MISMAS del proyecto de la web. Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Avisos al dueño (Resend) ──
# Opcionales. Sin ellas, escalar_con_dueno queda registrado pero no
# manda correo. Nada se rompe.
RESEND_API_KEY=
CORREO_REMITENTE=YoRespondo <avisos@respondo.com>

# ── Ajustes finos (opcionales) ──
# GRAPH_VERSION=v23.0
# MODELO_CLAUDE=claude-opus-4-8
